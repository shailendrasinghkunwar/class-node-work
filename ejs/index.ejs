<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            display: grid;
            place-items: center;
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #f4f7fb, #dfe9f3);
            color: #1f2937;
        }

        main {
            text-align: center;
            background: white;
            padding: 2rem;
            border-radius: 16px;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.12);
        }

        h1 {
            margin-bottom: 0.75rem;
        }
    </style>
</head>
<body>
    <main>
        <h1><%= title %></h1>
        <p><%= message %></p>
    </main>
</body>
</html>
